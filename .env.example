# Public browser map rendering key only. Restrict this key by HTTP referrer in Google Cloud.
VITE_GOOGLE_MAPS_BROWSER_KEY=

# Server-side only keys for a future backend/serverless proxy.
# Do not expose these through Vite or commit real values.
GOOGLE_PLACES_SERVER_KEY=
GOOGLE_ROUTES_SERVER_KEY=
GOOGLE_WEATHER_SERVER_KEY=

# Optional future National Weather Service identifier for backend requests.
NWS_USER_AGENT=LumaDate/0.1 contact@example.com
